# =========================================================
# Digital Anyork LLC — Landing de Diagnóstico
# Copia este archivo como .env.local y completa lo que uses.
# =========================================================

# --- URL pública del sitio (para SEO / Open Graph) ---
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# --- Convocatoria de 3 casos gratuitos ---
# true  = muestra "POSTULAR MI NEGOCIO" (convocatoria abierta)
# false = muestra "QUIERO AYUDA CON MI RESULTADO" (oferta pagada)
NEXT_PUBLIC_FREE_CASES_OPEN=true

# --- Proveedor de IA (opcional) ---
# Valores: openai | anthropic | gemini | groq
# Si se deja vacío o falla, se usa el motor de puntuación local automáticamente.
AI_PROVIDER=

# Solo necesitas la clave del proveedor que elijas:
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Base de leads ---
# Prioridad: Supabase > Airtable > archivo local /data/leads.json.
# En producción (Vercel) el archivo local NO persiste: configura Supabase.
SUPABASE_URL=
SUPABASE_KEY=

# Alternativa Airtable:
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Leads
